{
  "name": "harness-eval-lab",
  "displayName": "Harness Eval Lab",
  "version": "0.2.0",
  "description": "Evaluate AI agent setups for best practices, redundancy, security, and cross-component issues.",
  "author": {
    "name": "Benjamin Kapner"
  },
  "repository": "https://github.com/redhat-community-ai-tools/harness-eval-lab",
  "license": "Apache-2.0",
  "keywords": ["evaluation", "harness", "setup", "skills", "configuration", "security"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"${CLAUDE_PLUGIN_ROOT}/skills/eval-setup-lint/scripts/ensure_deps.py\" \"${CLAUDE_PLUGIN_DATA}\"",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
